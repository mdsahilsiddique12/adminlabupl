# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/license_portal?sslmode=require"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# RSA Keys (Required for Render)
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# CORS Configuration
ALLOWED_ORIGINS="https://your-frontend.netlify.app,http://localhost:5173,http://localhost:3000"

# Security
LOG_LEVEL="info"
NODE_ENV="production"

# Application
PORT="3000"

# Desktop App Encryption (Optional)
DESKTOP_ENCRYPTION_KEY="your-desktop-encryption-key"

# Email Delivery (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="LicenseOps <licenses@yourdomain.com>"
EMAIL_APP_NAME="LicenseOps"
